# ============================================
# Jules AI 代码生成平台 - 环境变量配置
# ============================================

# -------------------- 应用配置 --------------------
# 环境类型: development, staging, production
ENVIRONMENT=development

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# 应用密钥（生产环境必须修改）
SECRET_KEY=your-secret-key-change-in-production

# -------------------- 数据库配置 --------------------
# PostgreSQL 连接字符串
DATABASE_URL=postgresql://jules:jules_password@postgres:5432/jules_db

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# -------------------- Redis 配置 --------------------
# Redis 连接字符串
REDIS_URL=redis://redis:6379/0

# Celery 任务队列配置
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Redis 缓存过期时间（秒）
REDIS_CACHE_TTL=3600

# -------------------- LLM API 配置 --------------------
# Anthropic API（Claude）
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# OpenAI API（GPT）
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# -------------------- LangSmith 监控 --------------------
# LangSmith API（Agent 追踪和调试）
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=jules-dev
LANGSMITH_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# -------------------- 前端配置 --------------------
# API 基础 URL
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# 前端功能开关
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false

# -------------------- 代码质量工具配置 --------------------
# Ruff 配置
RUFF_MAX_LINE_LENGTH=100
RUFF_MAX_COMPLEXITY=10

# mypy 严格模式
MYPY_STRICT_MODE=true

# Radon 复杂度阈值
RADON_CC_THRESHOLD=10
RADON_MI_THRESHOLD=20

# Bandit 安全扫描级别
BANDIT_SEVERITY_LEVEL=LOW

# -------------------- Git 配置 --------------------
# Git 用户信息（用于自动提交）
GIT_USER_NAME=Jules AI Bot
GIT_USER_EMAIL=bot@jules-ai.dev

# Git 默认分支
GIT_DEFAULT_BRANCH=main

# -------------------- 认证和安全 --------------------
# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 允许的源（生产环境需要限制）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# 速率限制
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# -------------------- 任务配置 --------------------
# Celery Worker 并发数
CELERY_WORKER_CONCURRENCY=2

# 任务超时时间（秒）
TASK_SOFT_TIME_LIMIT=300
TASK_HARD_TIME_LIMIT=600

# 最大任务重试次数
TASK_MAX_RETRIES=3

# -------------------- 文件存储配置 --------------------
# 代码生成输出目录
CODE_OUTPUT_DIR=/app/output

# 临时文件目录
TEMP_DIR=/tmp/jules

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE_MB=10

# -------------------- 监控和告警 --------------------
# Sentry DSN（错误追踪）
SENTRY_DSN=

# Prometheus 监控端点
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# 健康检查端点
HEALTH_CHECK_ENABLED=true

# -------------------- 开发工具 --------------------
# 启用调试模式
DEBUG=true

# 启用热重载
HOT_RELOAD=true

# 启用 API 文档
ENABLE_DOCS=true
DOCS_URL=/docs
REDOC_URL=/redoc

# -------------------- 性能优化 --------------------
# 数据库查询慢查询阈值（毫秒）
SLOW_QUERY_THRESHOLD_MS=100

# API 响应缓存时间（秒）
API_CACHE_TTL=60

# 启用查询结果缓存
ENABLE_QUERY_CACHE=true

# -------------------- Agent 配置 --------------------
# Agent 最大执行时间（秒）
AGENT_MAX_EXECUTION_TIME=300

# Agent 最大重试次数
AGENT_MAX_RETRIES=3

# Agent 并行执行数
AGENT_MAX_PARALLEL=5

# -------------------- 通知配置 --------------------
# 邮件通知（可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@jules-ai.dev

# Slack 通知（可选）
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#jules-notifications

# -------------------- 备份配置 --------------------
# 数据库备份目录
BACKUP_DIR=/backups

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# 自动备份时间（Cron 表达式）
BACKUP_CRON_SCHEDULE=0 2 * * *
