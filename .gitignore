build/
dist/

# Misc
.turbo
*.tsbuildinfo

# Testing
coverage/
coverage.xml
coverage.json

# -------------------- 环境变量和配置 --------------------
# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# 敏感配置文件
secrets.yaml
secrets.json
*.key
*.pem
*.p12
*.pfx

# -------------------- 数据库 --------------------
# SQLite
*.db
*.sqlite
*.sqlite3

# PostgreSQL
*.sql.backup
*.dump

# 数据库数据目录
/postgres_data
/pgdata

# -------------------- Docker --------------------
# Docker 数据卷
docker-compose.override.yml

# -------------------- 日志和临时文件 --------------------
# 日志文件
*.log
logs/
*.out

# 临时文件
tmp/
temp/
*.tmp
*.temp
*.cache

# PID 文件
*.pid

# -------------------- 备份文件 --------------------
*.bak
*.backup
*.old
*.orig

# -------------------- 项目特定 --------------------
# 代码输出目录
/output
/generated

# 测试数据
/test-data

# 文档构建
/docs/_build
/docs/.doctrees

# 质量检查报告
.radon/
.wily/
bandit-report.json
mypy-report/

# LangSmith 本地缓存
.langsmith/

# Git 相关
*.patch
*.diff

# 压缩文件
*.zip
*.tar.gz
*.rar
*.7z

# -------------------- 保留必要的配置模板 --------------------
# 确保这些文件被追踪
!.env.example
!docker-compose.yml
!.gitignore
!README.md
